                    local distance = (LocalPlayer.Character.PrimaryPart.Position + LocalPlayer.Character.PrimaryPart.Velocity * (pingedValued / 2000) - (ball.Position + velocity * (pingedValued / 2000))).Magnitude
                    local curved, backwardsDetected = AutoParry.IsCurved(ball)
                    local adjustedPing = pingedValued / 10
                    local parryAccuracy = adjustedPing + math.max((speed / (2.4 + math.min(math.max(speed - 9.5, 0), 820) * 0.002 * Speed_Divisor_Multiplier)) * (0.8 + math.min(speed / 2000, 1.0)) * (1 + (30 - math.min(distance, 30)) / 30 * 0.8), 9.5)
                    if curved and backwardsDetected then parryAccuracy = parryAccuracy - (speed > 700 and 85 or (speed > 600 and 75 or (speed > 500 and 68 or (speed > 400 and 62 or 55))))
                    elseif curved then parryAccuracy = parryAccuracy - (speed > 700 and 58 or (speed > 600 and 52 or (speed > 500 and 46 or (speed > 400 and 42 or 38)))) end

                    if ballTarget == tostring(LocalPlayer) and distance <= parryAccuracy and not Phantom then
