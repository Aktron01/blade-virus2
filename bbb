--// UI Dragging Logic //--
local dragging, dragStart, startPos

ToggleButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = ToggleButton.Position
    end
end)

ToggleButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        ToggleButton.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

--// Toggle Logic //--
ToggleButton.MouseButton1Click:Connect(function()
    AutoParryEnabled = not AutoParryEnabled
    if AutoParryEnabled then
        ToggleButton.TextColor3 = Color3.fromRGB(80, 255, 80) -- Green
        UIStroke.Color = Color3.fromRGB(80, 255, 80)
        ToggleButton.Text = "OXYO: ON"
    else
        ToggleButton.TextColor3 = Color3.fromRGB(255, 80, 80) -- Red
        UIStroke.Color = Color3.fromRGB(255, 80, 80)
        ToggleButton.Text = "OXYO: OFF"
    end
end)

--// Safe Input Execution (Bypasses AC) //--
local lastClickTime = 0

local function SafeParry()
    -- Prevent impossible CPS (Clicks Per Second)
    if tick() - lastClickTime < 0.1 then return end
    lastClickTime = tick()

    -- Method 1: Try to fire the actual UI button (Most Undetectable)
    pcall(function()
        local hotbar = LocalPlayer.PlayerGui:FindFirstChild("Hotbar")
        local blockBtn = hotbar and hotbar:FindFirstChild("Block")
        if blockBtn and blockBtn:FindFirstChild("Button") then
            if firesignal then
                firesignal(blockBtn.Button.MouseButton1Click)
                return
            elseif getconnections then
                for _, conn in pairs(getconnections(blockBtn.Button.MouseButton1Click)) do
                    conn:Fire()
                end
                return
            end
        end
    end)

    -- Method 2: Humanized Virtual Input (Random coords & hold times)
    if isMobile then
        if mouse1click then mouse1click() end
    else
        local rx = math.random(250, 750) -- Random X coord
        local ry = math.random(250, 750) -- Random Y coord
        local holdTime = math.random(15, 35) / 1000 -- Hold between 15ms and 35ms

        VirtualInputManager:SendMouseButtonEvent(rx, ry, 0, true, game, 0)
        task.wait(holdTime)
        VirtualInputManager:SendMouseButtonEvent(rx, ry, 0, false, game, 0)
    end
end

--// Calculation Helpers //--
local function GetBall()
    local balls = Workspace:FindFirstChild("Balls")
    if not balls then return nil end
    for _, ball in pairs(balls:GetChildren()) do
        if ball:GetAttribute("realBall") then
            return ball
        end
    end
    return nil
end

local function GetPing()
    local success, ping = pcall(function()
        return game:GetService('Stats').Network.ServerStatsItem['Data Ping']:GetValue()
    end)
    return success and ping or 50
end

local function GetClosestPlayerDist(character)
    local maxDist = math.huge
    local aliveFolder = Workspace:FindFirstChild("Alive")
    if not aliveFolder then return maxDist end

    for _, entity in pairs(aliveFolder:GetChildren()) do
        if entity ~= character and entity.PrimaryPart then
            local dist = (character.PrimaryPart.Position - entity.PrimaryPart.Position).Magnitude
            if dist < maxDist then
                maxDist = dist
            end
        end
    end
    return maxDist
end

--// Main Combat Loop //--
RunService.PreSimulation:Connect(function()
    if not AutoParryEnabled then return end

    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then return end

    local ball = GetBall()
    if not ball then return end

    local zoomies = ball:FindFirstChild("zoomies")
    if not zoomies then return end

    -- Only check if the ball is targeting you
    if ball:GetAttribute("target") ~= tostring(LocalPlayer) then return end

    local velocity = zoomies.VectorVelocity
    local speed = velocity.Magnitude
    local distance = (char.PrimaryPart.Position - ball.Position).Magnitude

    local ping = GetPing()
    local pingAdjust = ping / 10

    -- [1] AUTO SPAM LOGIC
    local closestPlayerDist = GetClosestPlayerDist(char)
    local spamDistanceThreshold = pingAdjust + math.min(speed / 3.5, 90)

    if distance < spamDistanceThreshold and speed > 40 and closestPlayerDist < 25 then
        SafeParry()
        return
    end

    -- [2] AUTO PARRY LOGIC
    local cappedSpeedDifference = math.min(math.max(speed - 9.5, 0), 820)
    local speedDivisorBase = 2.4 + (cappedSpeedDifference * 0.002)
    local parryAccuracy = pingAdjust + math.max(speed / speedDivisorBase, 9.5)

    if distance <= parryAccuracy then
        SafeParry()
    end
end)
