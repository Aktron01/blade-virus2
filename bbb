AutoParry.Parry_Data = function(Parry_Type)
    if not LocalPlayer.Character or not LocalPlayer.Character.PrimaryPart then return nil end
    local Camera = workspace.CurrentCamera
    local Vector2_Mouse_Location = isMobileDevice and {Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2} or {UserInputService:GetMouseLocation().X, UserInputService:GetMouseLocation().Y}
    local Events, Players_Screen_Positions = {}, {}
    for _, v in pairs(workspace.Alive:GetChildren()) do
        if v ~= LocalPlayer.Character then
            local screenPos, isOnScreen = Camera:WorldToScreenPoint(v.PrimaryPart.Position)
            if isOnScreen then Players_Screen_Positions[v] = Vector2.new(screenPos.X, screenPos.Y) end
            Events[tostring(v)] = screenPos
        end
    end

    if Parry_Type == 'Camera' then return {0, Camera.CFrame, Events, Vector2_Mouse_Location}
    elseif Parry_Type == 'Backwards' then return {0, CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + Vector3.new(Camera.CFrame.LookVector.X * -10000, 0, Camera.CFrame.LookVector.Z * -10000)), Events, Vector2_Mouse_Location}
    elseif Parry_Type == 'Straight' then
        local Aimed_Player, Closest_Distance = nil, math.huge
        for v, pos in pairs(Players_Screen_Positions) do
            local distance = (Vector2.new(Vector2_Mouse_Location[1], Vector2_Mouse_Location[2]) - pos).Magnitude
            if distance < Closest_Distance then Closest_Distance = distance; Aimed_Player = v end
        end
        return {0, CFrame.new(LocalPlayer.Character.PrimaryPart.Position, Aimed_Player and Aimed_Player.PrimaryPart.Position or Closest_Entity.PrimaryPart.Position), Events, Vector2_Mouse_Location}
    elseif Parry_Type == 'Random' then
        local d = {"Backwards", "Left", "Right", "High"}[math.random(1, 4)]
        local v = (d == "Backwards" and Vector3.new(Camera.CFrame.LookVector.X * -10000, 0, Camera.CFrame.LookVector.Z * -10000)) or (d == "Left" and -Camera.CFrame.RightVector * 10000) or (d == "Right" and Camera.CFrame.RightVector * 10000) or (Camera.CFrame.UpVector * 10000)
        return {0, CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + v + Vector3.new(math.random(-500, 500), math.random(-500, 500), math.random(-500, 500))), Events, Vector2_Mouse_Location}
    elseif Parry_Type == 'High' then return {0, CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + Camera.CFrame.UpVector * 10000), Events, Vector2_Mouse_Location}
    elseif Parry_Type == 'Left' then return {0, CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position - Camera.CFrame.RightVector * 10000), Events, Vector2_Mouse_Location}
    elseif Parry_Type == 'Right' then return {0, CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + Camera.CFrame.RightVector * 10000), Events, Vector2_Mouse_Location}
    end
end

AutoParry.Parry = function(parryType)
