AutoParry.Linear_Interpolation = function(a, b, time_volume) return a + (b - a) * time_volume end

AutoParry.IsCurved = function(ball)
    if not ball or not ball:FindFirstChild('zoomies') then return false, false end
    local Velocity = ball.zoomies.VectorVelocity
    local Speed = Velocity.Magnitude
    if Speed < 60 or not AutoParry.Velocity_History[ball] or #AutoParry.Velocity_History[ball] < 2 or not AutoParry.Dot_Histories[ball] or #AutoParry.Dot_Histories[ball] < 2 then return false, false end
    local Ball_Direction = Velocity.Unit
    local Direction = (LocalPlayer.Character.PrimaryPart.Position - ball.Position).Unit
    local Dot = Direction:Dot(Ball_Direction)
    local Speed_Threshold = math.min(Speed / 100, 40)
    local Distance = (LocalPlayer.Character.PrimaryPart.Position - ball.Position).Magnitude
    local baseDotThreshold = Speed > 600 and -0.1 or (Speed > 400 and 0.0 or 0.15)
    local Dot_Threshold = baseDotThreshold - (GetAveragePing() / 2000) - math.min(Speed / 4000, 0.1)
    local Reach_Time = Distance / Speed - (GetAveragePing() / 1000)
    local Clamped_Dot = math.clamp(Dot, -1, 1)
    Lerp_Radians = AutoParry.Linear_Interpolation(Lerp_Radians, math.asin(math.abs(Clamped_Dot)), 0.8)
    if Lerp_Radians < 0.018 then Last_Warp_Time = tick() end
    if (tick() - Last_Warp_Time) < (Reach_Time / 1.5) or (tick() - Curve_Time) < (Reach_Time / 1.5) then return true, false end

    local backwardsCurveDetected = false
    local backwardsAngleThreshold = Speed > 600 and 50 or (Speed > 400 and 55 or 65)
    local playerPos = LocalPlayer.Character.PrimaryPart.Position
    local horizDirection = Vector3.new(playerPos.X - ball.Position.X, 0, playerPos.Z - ball.Position.Z)
    if horizDirection.Magnitude > 0 then horizDirection = horizDirection.Unit end
    local horizBallDir = Vector3.new(Ball_Direction.X, 0, Ball_Direction.Z)
    if horizBallDir.Magnitude > 0 then
        horizBallDir = horizBallDir.Unit
        if math.deg(math.acos(math.clamp((-horizDirection):Dot(horizBallDir), -1, 1))) < backwardsAngleThreshold and Distance > 30 then backwardsCurveDetected = true end
    end

    local directionChanged, changeThreshold = false, Speed > 600 and 0.75 or (Speed > 400 and 0.78 or 0.80)
    if AutoParry.Velocity_History[ball] and #AutoParry.Velocity_History[ball] >= 4 then
        local prevVel = AutoParry.Velocity_History[ball][#AutoParry.Velocity_History[ball] - 1]
        if prevVel.Magnitude > 100 and Speed > 100 and prevVel.Unit:Dot(Ball_Direction) < changeThreshold then directionChanged = true end
    end

    local dotVariance, significantVariance = 0, false
    if AutoParry.Dot_Histories[ball] and #AutoParry.Dot_Histories[ball] >= 5 then
        local hist = AutoParry.Dot_Histories[ball]
        for i = 2, #hist do dotVariance = dotVariance + math.abs(hist[i] - hist[i-1]) end
        dotVariance = dotVariance / (#hist - 1)
        if dotVariance > (Speed > 600 and 0.10 or (Speed > 400 and 0.09 or 0.08)) then significantVariance = true end
    end

    local curveConditions = (Dot < Dot_Threshold and 1 or 0) + (backwardsCurveDetected and 3 or 0) + (directionChanged and 1 or 0) + (significantVariance and 1 or 0)
    return curveConditions >= 3 or backwardsCurveDetected, backwardsCurveDetected
end

