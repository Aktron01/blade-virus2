function AcrylicBlur:create_depth_of_fields()
    local depth_of_fields = Lighting:FindFirstChild('AcrylicBlur') or Create("DepthOfFieldEffect", {
        FarIntensity = 0, FocusDistance = 0.05, InFocusRadius = 0.1, NearIntensity = 1, Name = 'AcrylicBlur', Parent = Lighting
    })
    for _, object in Lighting:GetChildren() do
        if object:IsA('DepthOfFieldEffect') and object ~= depth_of_fields then
            Connections[object] = object:GetPropertyChangedSignal('FarIntensity'):Connect(function() object.FarIntensity = 0 end)
            object.FarIntensity = 0
        end
    end
end

